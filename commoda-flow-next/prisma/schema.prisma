generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  rentals   Rental[]
}

model Hardware {
  id        String         @id @default(uuid())
  model     String
  specs     String
  category  Category
  dailyRate Float
  status    HardwareStatus @default(AVAILABLE)
  createdAt DateTime       @default(now())
  rentals   Rental[]
}

model Rental {
  id         String    @id @default(uuid())
  userId     String
  hardwareId String
  startDate  DateTime  @default(now())
  endDate    DateTime?
  totalPrice Float?
  hardware   Hardware  @relation(fields: [hardwareId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Category {
  LAPTOP
  TABLET
  PERIPHERAL
}

enum HardwareStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
}
